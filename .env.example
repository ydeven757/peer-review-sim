# ══════════════════════════════════════════════════════════════
#  Peer Review Simulator — Environment Configuration
# ══════════════════════════════════════════════════════════════
#
# Provider priority (first available wins):
#   1. Ollama    — local, no API key needed (best for testing)
#   2. Anthropic — Claude Sonnet 4
#   3. OpenAI    — GPT-4o (or compatible endpoint via OPENAI_BASE_URL)
#
# ── Ollama (recommended for local testing) ──────────────────
# No API key needed. Requires: ollama serve
# Install models:  ollama pull llama3
#                   ollama pull mistral
#                   ollama pull mixtral
#
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3

# ── Anthropic ───────────────────────────────────────────────
# Requires: pip install anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI ──────────────────────────────────────────────────
# Requires: pip install openai
# OPENAI_API_KEY=sk-...
# Optional: override base URL for compatible proxies
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
